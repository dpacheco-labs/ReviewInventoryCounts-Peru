# Configuración de Email para envío de reportes
# Renombra este archivo a "secrets.toml" y completa con tus credenciales

[email]
# Servidor SMTP
smtp_server = "smtp.gmail.com"  # Para Gmail
# smtp_server = "smtp.office365.com"  # Para Outlook/Office 365
# smtp_server = "smtp.abinbev.com"  # Servidor corporativo AB InBev (si aplica)

# Puerto SMTP (587 para TLS, 465 para SSL)
smtp_port = 587

# Email remitente (tu email)
sender_email = "tu-email@abinbev.com"

# Contraseña del email o App Password
# IMPORTANTE: Para Gmail, usa una "App Password" en lugar de tu contraseña normal
# Instrucciones: https://support.google.com/accounts/answer/185833
sender_password = "tu-contraseña-o-app-password"


# ============================================
# INSTRUCCIONES PARA CONFIGURAR
# ============================================

# GMAIL:
# 1. Habilita verificación en 2 pasos en tu cuenta Google
# 2. Genera una "App Password": https://myaccount.google.com/apppasswords
# 3. Usa esa contraseña aquí (16 caracteres sin espacios)
# 4. smtp_server = "smtp.gmail.com"
# 5. smtp_port = 587

# OUTLOOK/OFFICE 365:
# 1. smtp_server = "smtp.office365.com"
# 2. smtp_port = 587
# 3. sender_email = tu email de Outlook
# 4. sender_password = tu contraseña de Outlook

# SERVIDOR CORPORATIVO AB INBEV:
# Contacta a tu equipo de IT para obtener:
# - Dirección del servidor SMTP
# - Puerto a usar
# - Credenciales autorizadas

# ============================================
# SEGURIDAD
# ============================================
# Este archivo NO se subirá a GitHub (está en .gitignore)
# NUNCA compartas este archivo con tus credenciales
# Mantén tu contraseña segura
